<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup>
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>
    <connectionStrings>
        <!--
            SESUAIKAN connection string di bawah ini:
            - Server=.\SQLEXPRESS  → gunakan nama SQL Server instance Anda
            - Database=SistemNutrisi → nama database yang Anda buat
            - Trusted_Connection=True → Windows Authentication (tanpa username/password)
            
            Jika menggunakan SQL Server Authentication, ganti dengan:
            Server=NAMA_SERVER;Database=SistemNutrisi;User Id=sa;Password=PASSWORD_ANDA;
        -->
        <add name="SistemNutrisiDB"
             connectionString="Data Source=IZAYAAA\IZA;Initial Catalog=DBSistemNutrisi;Integrated Security=True;MultipleActiveResultSets=True;"
             providerName="System.Data.SqlClient" />
    </connectionStrings>
    <system.diagnostics>
        <switches>
            <add name="ConnectionSwitch" value="1"/>
        </switches>
    </system.diagnostics>
</configuration>